<%- include('head') %>
<% if (typeof error !== 'undefined') { %>
  <p class="login-error">密码错误，请重试。</p>
<% } %>
<form method="POST" action="/login" class="login-form">
  <h2>请输入密码</h2>
  <input type="password" name="password" placeholder="密码" autofocus required>
  <button type="submit">进入</button>
</form>
<%- include('foot') %>
